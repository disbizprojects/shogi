# SHOGI Systems - Nginx Reverse Proxy Configuration
# 
# This file demonstrates how to set up nginx as a reverse proxy
# Place this in /etc/nginx/sites-available/shogisystems.com
#
# Then enable it with:
#   sudo ln -s /etc/nginx/sites-available/shogisystems.com /etc/nginx/sites-enabled/
#   sudo nginx -t
#   sudo systemctl reload nginx

upstream shogi_backend {
    server 127.0.0.1:3000;
    keepalive 64;
}

# Redirect HTTP to HTTPS
server {
    listen 80;
    listen [::]:80;
    server_name shogisystems.com www.shogisystems.com;
    
    return 301 https://$server_name$request_uri;
}

# HTTPS Server
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name shogisystems.com www.shogisystems.com;

    # SSL Certificates (obtain from Let's Encrypt)
    ssl_certificate /etc/letsencrypt/live/shogisystems.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/shogisystems.com/privkey.pem;

    # SSL Configuration
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;
    ssl_prefer_server_ciphers on;
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 10m;

    # Security Headers
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;

    # Gzip compression
    gzip on;
    gzip_types text/html text/css text/javascript application/javascript;
    gzip_vary on;

    # Root location
    location / {
        proxy_pass https://shogi_backend;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
    }

    # Enterprise Dashboard Preview
    location /enterprise-dashboard-preview {
        proxy_pass https://shogi_backend/enterprise-dashboard-preview;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_cache_bypass $http_upgrade;
    }

    # Policy Configuration Preview
    location /policy-configuration-preview {
        proxy_pass https://shogi_backend/policy-configuration-preview;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_cache_bypass $http_upgrade;
    }

    # Deny access to hidden files
    location ~ /\. {
        deny all;
    }

    # Client body size limit
    client_max_body_size 10M;
}
