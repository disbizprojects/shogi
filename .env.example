# SHOGI Preview Server - Environment Configuration
# Copy this file to .env and customize for your environment

# Node Environment
NODE_ENV=production

# Server Port
# Default: 443 (HTTPS) or 80 (HTTP if no certs)
PORT=443

# SSL/TLS Certificate Paths
# Leave blank for self-signed in ./certs/
# Or specify full paths for custom locations
SSL_KEY_PATH=./certs/private-key.pem
SSL_CERT_PATH=./certs/certificate.pem

# Domain Configuration
DOMAIN=shogisystems.com

# Logging
LOG_LEVEL=info

# Security
# CORS allowed origins (comma-separated)
CORS_ORIGINS=*

# Add X-Powered-By header
SHOW_POWERED_BY=false

# Session timeout (milliseconds)
SESSION_TIMEOUT=3600000

# Max request size
MAX_REQUEST_SIZE=10mb

# Enable compression
COMPRESSION_ENABLED=true
COMPRESSION_LEVEL=6

# Cache control
CACHE_CONTROL=public, max-age=3600

# Security headers
ENABLE_SECURITY_HEADERS=true
